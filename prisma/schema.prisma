// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  pid         Int      @default(autoincrement()) @id
  name        String?   @unique
  elo         Int
  numMatches  Int
}